---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getArtifacts, normalizeSlug, formatDate } from "@/lib/content/queries";

const artifacts = await getArtifacts();
---

<BaseLayout title="Artifacts" crumbs={[{ label: "Home", href: "/" }, { label: "Artifacts" }]}> 
  <section class="section-stack">
    <div class="section-heading-row">
      <h1>Artifacts</h1>
      <span class="meta-row">项目、论文、数据与公开成果</span>
    </div>

    <div class="editorial-grid-wide">
      {
        artifacts.map((entry, idx) => (
          <a class={`card ${idx === 0 ? "card--hero card--overlay" : ""}`} href={`/artifacts/${normalizeSlug(entry)}/`}>
            {
              entry.data.cover ? (
                <img class="card-cover" src={entry.data.cover} alt={entry.data.title} loading={idx === 0 ? "eager" : "lazy"} />
              ) : (
                <div class="card-cover placeholder-cover" data-variant={((idx % 6) + 1).toString()}>
                  <span style="font-size: 0.8rem; opacity: 0.6;">{entry.data.type}</span>
                </div>
              )
            }
            <div class="card-body">
              <h3>{entry.data.title}</h3>
              <p>{entry.data.summary}</p>
              <div class="meta-row">
                <span class="tag-chip">{entry.data.type}</span>
                <span>{formatDate(entry.data.date)}</span>
              </div>
              {entry.data.tags.length > 0 && (
                <div class="meta-row">
                  {entry.data.tags.slice(0, 3).map((tag: string) => <span class="tag-chip">{tag}</span>)}
                </div>
              )}
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
