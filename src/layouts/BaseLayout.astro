---
import "@/styles/main.css";
import { ViewTransitions } from "astro:transitions";
import Sidebar from "@/components/layout/Sidebar.astro";
import Topbar from "@/components/layout/Topbar.astro";
import CommandPalette from "@/components/search/CommandPalette.astro";
import PagefindFilters from "@/components/search/PagefindFilters.astro";
import { getSiteConfig } from "@/lib/content/queries";

interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  description?: string;
  crumbs?: Crumb[];
  pagefindFilters?: Record<string, string | number | Array<string | number> | null | undefined>;
}

const { title, description = "Chika Komari's research and engineering website", crumbs = [], pagefindFilters = {} } = Astro.props;
const { home, taxonomy } = await getSiteConfig();

const quickLinks = home?.quick_links?.length
  ? home.quick_links
  : [
      { label: "GitHub", url: "https://github.com/Joker-of-Gotham", external: true },
      { label: "Kaggle", url: "https://www.kaggle.com/gothamjocker", external: true }
    ];
const pinnedTracks = home?.pinned_tracks?.length ? home.pinned_tracks : taxonomy?.tracks ?? [];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | Chika Komari</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" /></noscript>
    <ViewTransitions />
    <slot name="head" />
  </head>
  <body>
    <div class="site-shell">
      <Sidebar pathname={Astro.url.pathname} quickLinks={quickLinks} pinnedTracks={pinnedTracks} />

      <div class="main-area">
        <Topbar title={title} crumbs={crumbs} />
        <slot name="full-bleed" />
        <main class="main-container" data-pagefind-body>
          <PagefindFilters filters={pagefindFilters} />
          <slot />
        </main>
      </div>
    </div>

    <CommandPalette />

    <script>
      let _sidebarAC: AbortController | null = null;
      function initSidebar() {
        _sidebarAC?.abort();
        _sidebarAC = new AbortController();
        const sig = _sidebarAC.signal;

        const sidebar = document.getElementById("site-sidebar");
        const toggle = document.getElementById("drawer-toggle");
        if (!sidebar || !toggle) return;

        function closeSidebar() {
          sidebar!.classList.remove("open");
          document.querySelector(".mobile-mask")?.remove();
        }
        function openSidebar() {
          sidebar!.classList.add("open");
          if (!document.querySelector(".mobile-mask")) {
            const mask = document.createElement("button");
            mask.className = "mobile-mask";
            mask.setAttribute("aria-label", "Close sidebar");
            mask.addEventListener("click", closeSidebar);
            document.body.appendChild(mask);
          }
        }

        toggle.addEventListener("click", (e) => {
          e.stopPropagation();
          sidebar.classList.contains("open") ? closeSidebar() : openSidebar();
        }, { signal: sig });

        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && sidebar.classList.contains("open")) closeSidebar();
        }, { signal: sig });
      }
      document.addEventListener("astro:page-load", initSidebar);
    </script>

    <script>
      function initAnimations() {
        const els = document.querySelectorAll("[data-animate]:not(.in-view)");
        if (!els.length) return;

        const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (prefersReduced) {
          els.forEach((el) => (el as HTMLElement).classList.add("in-view"));
          return;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                (e.target as HTMLElement).classList.add("in-view");
                observer.unobserve(e.target);
              }
            });
          },
          { threshold: 0.05, rootMargin: "0px 0px -20px 0px" }
        );
        els.forEach((el) => observer.observe(el));
      }
      document.addEventListener("astro:page-load", initAnimations);
    </script>

    <script>
      let _carouselAC: AbortController | null = null;
      function initHeroCarousel() {
        _carouselAC?.abort();
        _carouselAC = new AbortController();
        const sig = _carouselAC.signal;

        const slides = document.querySelectorAll("#hero-carousel .hero-carousel-slide");
        const dots = document.querySelectorAll("#hero-carousel-dots .hero-carousel-dot");
        if (slides.length <= 1) return;

        let current = 0;
        let timer: ReturnType<typeof setInterval>;

        function goTo(idx: number) {
          if (idx === current) return;
          slides[current].classList.remove("is-active");
          dots[current]?.classList.remove("is-active");
          current = idx;
          slides[current].classList.add("is-active");
          dots[current]?.classList.add("is-active");
          clearInterval(timer);
          timer = setInterval(() => goTo((current + 1) % slides.length), 6000);
        }

        dots.forEach((dot) => {
          dot.addEventListener("click", () => goTo(parseInt((dot as HTMLElement).dataset.idx || "0", 10)), { signal: sig });
        });

        sig.addEventListener("abort", () => clearInterval(timer));
        timer = setInterval(() => goTo((current + 1) % slides.length), 6000);
      }
      document.addEventListener("astro:page-load", initHeroCarousel);
    </script>

    <script>
      // @ts-nocheck
      const rootWindow = window;

      if (!rootWindow["__jokerEnhancers"]) {
        rootWindow["__jokerEnhancers"] = {
          mermaidPromise: null,
          bound: false
        };
      }

      const extractLanguage = (codeElement) => {
        const className = Array.from(codeElement.classList).find((token) => token.startsWith("language-"));
        return className ? className.replace("language-", "") : "";
      };

      const decorateCodeBlocks = (scope = document) => {
        scope.querySelectorAll("pre").forEach((pre) => {
          if (!(pre instanceof HTMLElement)) return;
          if (pre.dataset.codeDecorated === "1") return;

          const code = pre.querySelector("code");
          if (!(code instanceof HTMLElement)) return;

          const language = extractLanguage(code) || pre.dataset.language || "text";
          pre.dataset.lang = String(language).toUpperCase();
          pre.dataset.codeDecorated = "1";
        });
      };

      const markerPattern = /^\s*\{:\s*((?:\.[a-zA-Z0-9_-]+\s*)+)\}\s*$/;
      const parseMarkerClasses = (raw) =>
        raw
          .split(/\s+/)
          .map((item) => item.trim())
          .filter(Boolean)
          .map((item) => (item.startsWith(".") ? item.slice(1) : item))
          .filter(Boolean);

      const cleanupLegacyMarkers = (scope = document) => {
        const candidates = scope.querySelectorAll(".content p, .content li");
        candidates.forEach((node) => {
          if (!(node instanceof HTMLElement)) return;
          const text = (node.textContent ?? "").trim();
          const marker = text.match(markerPattern);
          if (!marker) return;

          const classes = parseMarkerClasses(marker[1]);
          if (classes.length === 0) {
            node.remove();
            return;
          }

          let target = node.previousElementSibling;
          const parent = node.parentElement;

          if (!target && parent?.tagName.toLowerCase() === "blockquote") {
            target = parent;
          }

          if (target instanceof HTMLElement) {
            target.classList.add("callout");
            classes.forEach((name) => target.classList.add(name));
          }

          node.remove();
        });
      };

      const isMermaidPre = (node) => {
        if (!(node instanceof HTMLElement)) return false;
        const preLanguage = node.dataset.language?.toLowerCase();
        if (preLanguage === "mermaid") return true;
        const code = node.querySelector("code");
        if (!(code instanceof HTMLElement)) return false;
        return Array.from(code.classList).some((item) => item.toLowerCase() === "language-mermaid");
      };

      const loadMermaid = async () => {
        if (!rootWindow["__jokerEnhancers"].mermaidPromise) {
          rootWindow["__jokerEnhancers"].mermaidPromise = import("mermaid")
            .then((module) => {
              const mermaid = module.default ?? module;
              mermaid.initialize({
                startOnLoad: false,
                securityLevel: "loose",
                theme: "dark"
              });
              return mermaid;
            })
            .catch(() => null);
        }

        return rootWindow["__jokerEnhancers"].mermaidPromise;
      };

      const renderMermaidBlocks = async (scope = document) => {
        const codeBlocks = Array.from(scope.querySelectorAll("pre")).filter((node) => isMermaidPre(node));
        if (codeBlocks.length === 0) return;

        const mermaid = await loadMermaid();
        if (!mermaid) return;

        codeBlocks.forEach((preBlock, index) => {
          if (!(preBlock instanceof HTMLElement)) return;
          if (preBlock.dataset.mermaidRendered === "1") return;

          const codeBlock = preBlock.querySelector("code");
          if (!(codeBlock instanceof HTMLElement)) return;
          const source = (codeBlock.textContent ?? "").trim();
          if (!source) return;

          const wrapper = document.createElement("div");
          wrapper.className = "mermaid-block card";

          const body = document.createElement("div");
          body.className = "card-body";

          const mermaidNode = document.createElement("div");
          mermaidNode.className = "mermaid";
          mermaidNode.dataset.key = `${Date.now()}-${index}`;
          mermaidNode.textContent = source;

          body.appendChild(mermaidNode);
          wrapper.appendChild(body);
          preBlock.dataset.mermaidRendered = "1";
          preBlock.replaceWith(wrapper);
        });

        try {
          await mermaid.run({
            querySelector: ".mermaid-block .mermaid"
          });
        } catch (_error) {
          return;
        }
      };

      const schedule = (fn: () => void) => {
        if ("requestIdleCallback" in window) {
          (window as any).requestIdleCallback(fn, { timeout: 2000 });
        } else {
          setTimeout(fn, 50);
        }
      };

      const applyEnhancements = () => {
        schedule(() => {
          decorateCodeBlocks(document);
          cleanupLegacyMarkers(document);
        });
        schedule(() => void renderMermaidBlocks(document));
      };

      if (!rootWindow["__jokerEnhancers"].bound) {
        rootWindow["__jokerEnhancers"].bound = true;
        document.addEventListener("astro:page-load", applyEnhancements);
        document.addEventListener("astro:after-swap", applyEnhancements);
      }

      applyEnhancements();
    </script>
  </body>
</html>
