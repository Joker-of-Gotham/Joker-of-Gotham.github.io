---
export interface Props {
  status: "now" | "next" | "later" | "done" | "blocked";
}

const { status } = Astro.props;
const labels = {
  now: "Ongoing",
  blocked: "Blocked",
  next: "Planned",
  later: "Pending",
  done: "Completed"
};
---

<span class={`badge ${status}`}>{labels[status]}</span>
